<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top Bar: Logo + Tên app -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_app_icon">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="@color/colorPrimary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The Commons"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextDark"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- Back to Login -->
        <LinearLayout
            android:id="@+id/llBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/colorTextGray"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Back to Login"
                android:textSize="14sp"
                android:textColor="@color/colorTextGray"/>
        </LinearLayout>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset Password"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextDark"
                android:layout_marginBottom="12dp"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter the email address associated with your account and we'll send you a secure link to create a new password."
                android:textSize="14sp"
                android:textColor="@color/colorTextGray"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="28dp"/>

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textSize="11sp"
                android:textColor="@color/colorTextGray"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <!-- Email input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_dialog_email"
                    app:tint="@color/colorTextHint"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="yourname@domain.com"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextDark"
                    android:textColorHint="@color/colorTextHint"
                    android:paddingStart="10dp"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"/>
            </LinearLayout>

            <!-- Error text -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/colorRed"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <!-- Success text -->
            <TextView
                android:id="@+id/tvSuccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/colorStatusGreen"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <!-- Send Reset Button -->
            <Button
                android:id="@+id/btnSendReset"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_primary"
                android:text="Send Reset Link ▷"
                android:textColor="@color/colorWhite"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <!-- Contact support -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Still having trouble?  "
                    android:textSize="13sp"
                    android:textColor="@color/colorTextGray"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Community Support"
                    android:textSize="13sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Security Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_white"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <!-- Text bên trái -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SECURITY FIRST"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reset links are valid for 24 hours. Check your spam folder if it doesn't arrive within 2 minutes."
                    android:textSize="13sp"
                    android:textColor="@color/colorTextGray"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>

            <!-- Shield icon bên phải -->
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                app:tint="@color/colorInputBg"
                android:layout_marginStart="16dp"/>

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2024 THE COMMONS • LIVING ROOM FOR THE DIGITAL AGE"
            android:textSize="10sp"
            android:textColor="@color/colorTextHint"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>