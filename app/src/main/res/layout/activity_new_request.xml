<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/ivClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/colorTextDark"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="New Request"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextDark"
                android:layout_marginStart="4dp"/>

            <ImageView
                android:id="@+id/ivNotification"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="@color/colorPrimary"
                android:layout_marginEnd="8dp"/>

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle"
                android:src="@android:drawable/ic_menu_myplaces"
                android:padding="7dp"
                android:tint="@color/colorPrimary"/>
        </LinearLayout>

        <!-- Title + subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What do you need?"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextDark"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your community is here to help. Share what you're looking for and someone might have it to spare."
            android:textSize="14sp"
            android:textColor="@color/colorTextGray"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="24dp"/>

        <!-- ===== ITEM TITLE ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ITEM TITLE"
            android:textSize="11sp"
            android:textColor="@color/colorTextGray"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/etItemTitle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="e.g., Electric Drill or Garden Soil"
                android:textSize="15sp"
                android:textColor="@color/colorTextDark"
                android:textColorHint="@color/colorTextHint"
                android:maxLines="1"
                android:inputType="text"/>
        </LinearLayout>

        <!-- ===== DESCRIPTION ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESCRIPTION"
            android:textSize="11sp"
            android:textColor="@color/colorTextGray"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_input_field"
            android:hint="Tell the community a bit more about why you need this or for how long..."
            android:textSize="14sp"
            android:textColor="@color/colorTextDark"
            android:textColorHint="@color/colorTextHint"
            android:gravity="top|start"
            android:padding="16dp"
            android:inputType="textMultiLine"
            android:layout_marginBottom="16dp"/>

        <!-- ===== URGENCY LEVEL ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URGENCY LEVEL"
            android:textSize="11sp"
            android:textColor="@color/colorTextGray"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Low -->
            <LinearLayout
                android:id="@+id/llUrgencyLow"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_urgency_inactive"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_day"
                    android:tint="@color/colorTextGray"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low"
                    android:textSize="13sp"
                    android:textColor="@color/colorTextGray"/>
            </LinearLayout>

            <!-- Medium -->
            <LinearLayout
                android:id="@+id/llUrgencyMedium"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_urgency_active"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivMediumIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:tint="@color/colorPrimary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"/>
            </LinearLayout>

            <!-- High -->
            <LinearLayout
                android:id="@+id/llUrgencyHigh"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_urgency_inactive"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    android:tint="@color/colorTextGray"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textSize="13sp"
                    android:textColor="@color/colorTextGray"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== ADD REFERENCE PHOTO ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADD A REFERENCE PHOTO"
            android:textSize="11sp"
            android:textColor="@color/colorTextGray"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llAddPhoto"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_photo_placeholder"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Hiện khi chưa có ảnh -->
            <LinearLayout
                android:id="@+id/llPhotoPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:tint="@color/colorPrimary"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add a reference photo"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optional but helpful"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextGray"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Hiện khi đã có ảnh -->
            <ImageView
                android:id="@+id/ivReferencePhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Optional but helpful"
            android:textSize="12sp"
            android:textColor="@color/colorTextHint"
            android:layout_marginBottom="24dp"/>

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorRed"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Post Request Button -->
        <Button
            android:id="@+id/btnPostRequest"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_primary"
            android:text="Post Request"
            android:textColor="@color/colorWhite"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>