<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- OSMDroid MapView -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_above="@id/llItemCard"
        android:layout_height="match_parent"/>

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorWhite"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="4dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/colorPrimary"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvMapTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Item Location"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextDark"/>

        <ImageView
            android:id="@+id/ivMyLocation"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="@color/colorPrimary"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Card item info dưới cùng -->
    <LinearLayout
        android:id="@+id/llItemCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorWhite"
        android:padding="16dp"
        android:layout_alignParentBottom="true"
        android:elevation="8dp"
        android:visibility="gone">

        <!-- Item info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/ivItemImage"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_featured_card"
                android:src="@android:drawable/ic_menu_gallery"
                android:scaleType="centerCrop"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Status badge -->
                <TextView
                    android:id="@+id/tvItemStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AVAILABLE NOW"
                    android:textSize="10sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvItemTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Item Title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"/>

                <TextView
                    android:id="@+id/tvOwnerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Owner"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextGray"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Favorite icon -->
            <ImageView
                android:id="@+id/ivFavorite"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/btn_star_big_off"
                app:tint="@color/colorPrimary"/>
        </LinearLayout>

        <!-- Address + Distance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_item_map"
                app:tint="@color/colorPrimary"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvItemAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Address"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculating..."
                    android:textSize="12sp"
                    android:textColor="@color/colorTextGray"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnViewDetail"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="View Detail"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnOpenMap"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="Open in Maps"
                android:textColor="@color/colorWhite"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>