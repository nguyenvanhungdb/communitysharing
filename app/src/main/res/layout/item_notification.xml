<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/llNotificationItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_notification_unread"
    android:padding="14dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon theo loại thông báo -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_notif_icon_bg"
            android:src="@android:drawable/ic_dialog_info"
            android:padding="10dp"
            app:tint="@color/colorWhite"/>
    </FrameLayout>

    <!-- Nội dung thông báo -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notification Title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextDark"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2m ago"
                android:textSize="11sp"
                android:textColor="@color/colorTextHint"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Message -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification message content here"
            android:textSize="13sp"
            android:textColor="@color/colorTextGray"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginTop="4dp"/>

        <!-- Action buttons (chỉ hiện với borrow_request) -->
        <LinearLayout
            android:id="@+id/llActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="Accept"
                android:textColor="@color/colorWhite"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnDecline"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="Decline"
                android:textColor="@color/colorPrimary"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Action buttons (chỉ hiện với pickup_approved) -->
        <LinearLayout
            android:id="@+id/llPickupActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnCoordinatePickup"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="Coordinate Pickup"
                android:textColor="@color/colorWhite"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnViewListing"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="View Listing"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Reply Now (chỉ hiện với new_message) -->
        <TextView
            android:id="@+id/tvReplyNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPLY NOW →"
            android:textSize="12sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>