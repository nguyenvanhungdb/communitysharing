            <LinearLayout
                android:id="@+id/llFeatured"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_featured_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <!-- Icon + Text bên trái -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_need_something"
                        android:textSize="10sp"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_ask_community"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextDark"/>
                </LinearLayout>

                <!-- Nút bên phải -->
                <Button
                    android:id="@+id/btnRequestFeatured"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/home_request_short"
                    android:textColor="@color/colorWhite"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"/>

            </LinearLayout>

            <!-- Nearby Today Header -->
            <LinearLayout
