            <!-- Featured Share Card - sửa lại có ảnh + button -->
            <LinearLayout
                android:id="@+id/llFeatured"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_featured_card"
                android:padding="20dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FEATURED SHARE"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvFeaturedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fresh Garden Produce Bundle"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_mapmode"
                        app:tint="@color/colorTextGray"/>

                    <TextView
                        android:id="@+id/tvFeaturedDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Nearby"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextGray"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnRequestFeatured"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Request Item"
                    android:textColor="@color/colorWhite"
                    android:textSize="13sp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
            </LinearLayout>

            <!-- Nearby Today Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nearby Today"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"/>

                <TextView
                    android:id="@+id/tvViewMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Map"
                    android:textSize="13sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- RecyclerView dạng Grid 2 cột -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="16dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

        </LinearLayout>
    </ScrollView>

