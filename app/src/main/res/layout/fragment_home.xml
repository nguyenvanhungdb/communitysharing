<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_avatar"
            android:background="@drawable/bg_avatar_circle"
            android:padding="8dp" />

        <!-- App Name -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextDark"
            android:layout_marginStart="10dp"/>

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp">

            <!-- Icon chuông -->
            <ImageView
                android:id="@+id/ivNotification"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell"
                app:tint="@color/colorPrimary"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Badge -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="end|top"

                android:background="@drawable/bg_badge_red"
                android:gravity="center"

                android:text="1"
                android:textColor="@android:color/white"
                android:textSize="7sp"
                android:textStyle="bold"
                android:translationX="1dp"
                android:translationY="-1dp"
                android:visibility="visible" />
        </FrameLayout>

        <Space
            android:layout_width="10dp"
            android:layout_height="0dp"/>

        <!-- Add button -->
        <ImageView
            android:id="@+id/ivNewRequest"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/colorPrimary"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"


        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_card_white"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/colorTextHint"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/home_search_hint"
                android:textSize="14sp"
                android:textColorHint="@color/colorTextHint"
                android:textColor="@color/colorTextDark"
                android:paddingStart="8dp"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:inputType="text"/>
        </LinearLayout>

        <!-- Filter button -->
        <FrameLayout
            android:id="@+id/btnFilter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_card_white">
            <ImageView
                android:id="@+id/ivFilter"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/colorPrimary"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Category Tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/llCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Tab All Items (mặc định active) -->
            <TextView
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/category_all_items"
                android:textSize="13sp"
                android:textColor="@color/colorWhite"
                android:textStyle="bold"
                android:background="@drawable/bg_tab_active"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabFood"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/category_food"
                android:textSize="13sp"
                android:textColor="@color/colorTextGray"
                android:background="@drawable/bg_tab_inactive"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabClothes"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/category_clothes"
                android:textSize="13sp"
                android:textColor="@color/colorTextGray"
                android:background="@drawable/bg_tab_inactive"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabTools"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/category_tools"
                android:textSize="13sp"
                android:textColor="@color/colorTextGray"
                android:background="@drawable/bg_tab_inactive"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

