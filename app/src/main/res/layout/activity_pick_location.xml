<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- OSMDroid MapView -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapPickLocation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top bar nổi trên map -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/colorWhite"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/colorPrimary"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pick Item Location"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextDark"/>

            <ImageView
                android:id="@+id/ivMyLocation"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="@color/colorPrimary"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Search box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/colorWhite"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/colorTextHint"/>

                <EditText
                    android:id="@+id/etSearchLocation"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Search for a location..."
                    android:textSize="14sp"
                    android:textColor="@color/colorTextDark"
                    android:textColorHint="@color/colorTextHint"
                    android:paddingStart="8dp"
                    android:maxLines="1"
                    android:imeOptions="actionSearch"
                    android:inputType="text"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Pin ở giữa màn hình -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_centerInParent="true"
        android:layout_marginBottom="36dp"
        android:src="@drawable/ic_item_map"
        app:tint="@color/colorPrimary"/>

    <!-- Card dưới cùng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorWhite"
        android:padding="16dp"
        android:layout_alignParentBottom="true"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECTED LOCATION"
            android:textSize="10sp"
            android:textColor="@color/colorTextHint"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_item_map"
                app:tint="@color/colorPrimary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvSelectedAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Move the map to select location"
                android:textSize="14sp"
                android:textColor="@color/colorTextDark"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirmLocation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_primary"
            android:text="Confirm This Location"
            android:textColor="@color/colorWhite"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

</RelativeLayout>