<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorWhite"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <!-- Back button -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/colorPrimary"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Avatar -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/ic_menu_myplaces"
            android:padding="8dp"
            app:tint="@color/colorPrimary"
            android:layout_marginEnd="10dp"/>

        <!-- Name + status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvOtherUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/common_user_name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextDark"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/common_active_now"
                android:textSize="11sp"
                android:textColor="@color/colorStatusGreen"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- Icons bên phải -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_call"
            app:tint="@color/colorPrimary"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="@color/colorPrimary"/>
    </LinearLayout>

    <!-- Danh sách tin nhắn -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <!-- Input box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorWhite"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:elevation="8dp">

        <!-- Plus button -->
        <ImageView
            android:id="@+id/btnAdd"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/colorPrimary"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Text input -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="@string/chat_type_message_hint"
            android:textSize="14sp"
            android:textColor="@color/colorTextDark"
            android:textColorHint="@color/colorTextHint"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionSend"/>

        <!-- Emoji button -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_add"
            app:tint="@color/colorTextHint"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Send button -->
        <FrameLayout
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_primary"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/colorWhite"/>
        </FrameLayout>
    </LinearLayout>

</LinearLayout>