<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="16dp"
    android:paddingBottom="90dp"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
    <!-- HEADER -->

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/colorPrimary"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- TITLE -->

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="56dp"
        android:layout_marginTop="8dp"
        android:text="@string/app_name"
        android:textColor="@color/colorTextDark"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/filter_title"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextDark"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SUBTITLE -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/filter_subtitle"
        android:textSize="13sp"
        android:textColor="@color/colorTextGray"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- AVAILABILITY -->
    <TextView
        android:id="@+id/tvAvailability"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_status"
        android:textSize="10sp"
        android:textColor="@color/colorTextGray"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutToggle"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAvailability"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnAvailable"
            android:layout_width="131dp"
            android:layout_height="38dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:text="@string/common_available"
            android:textColor="@color/colorTextDark"
            android:textSize="14sp"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.833" />

        <TextView
            android:id="@+id/btnNeeded"
            android:layout_width="141dp"
            android:layout_height="41dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:text="@string/filter_needed"
            android:textColor="@color/colorTextDark"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.666" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CATEGORY -->
    <TextView
        android:id="@+id/tvCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_categories"
        android:textSize="10sp"
        android:textColor="@color/colorTextGray"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/layoutToggle"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSelected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_selected_count"
        android:textSize="10sp"
        android:textColor="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="@id/tvCategory"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutChips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvCategory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ROW 1 -->
        <TextView
            android:id="@+id/chip1"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_furniture"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/chip2"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_food"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toEndOf="@id/chip1"
            app:layout_constraintTop_toTopOf="@id/chip1"/>

        <TextView
            android:id="@+id/chip3"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_clothes"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toEndOf="@id/chip2"
            app:layout_constraintTop_toTopOf="@id/chip1"/>

        <!-- ROW 2 -->
        <TextView
            android:id="@+id/chip4"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_tool"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chip1"/>

        <TextView
            android:id="@+id/chip5"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_electronic"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toEndOf="@id/chip4"
            app:layout_constraintTop_toTopOf="@id/chip4"/>

        <TextView
            android:id="@+id/chip6"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_kitchen"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toEndOf="@id/chip5"
            app:layout_constraintTop_toTopOf="@id/chip4"/>

        <!-- ROW 3 -->
        <TextView
            android:id="@+id/chip7"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_garden"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chip4"/>

        <TextView
            android:id="@+id/chip8"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_book"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toEndOf="@id/chip7"
            app:layout_constraintTop_toTopOf="@id/chip7"/>

        <TextView
            android:id="@+id/chip9"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="@string/category_others"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"
            app:layout_constraintWidth_percent="0.3"
            app:layout_constraintStart_toEndOf="@id/chip8"
            app:layout_constraintTop_toTopOf="@id/chip7"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutRadius"
            android:layout_width="327dp"
            android:layout_height="57dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_featured_card"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutChips">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="@string/filter_radius"
                android:textColor="@color/colorTextGray"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvMiles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="@string/filter_miles"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvMiles" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- TIME -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_time_posted"
        android:textSize="10sp"
        android:textColor="@color/colorTextGray"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/layoutRadius"
        app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/layoutTime"
            android:layout_width="327dp"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTime">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/colorTextDark" />

            <TextView
                android:id="@+id/tvTimeSelected"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/filter_last_24_hours"
                android:textColor="@color/colorTextDark"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/colorTextDark" />
        </LinearLayout>

    <!-- BUTTONS -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/filter_reset"
            android:gravity="center"
            android:textSize="14sp"
            android:background="@drawable/bg_button_secondary"
            android:textColor="@color/colorTextDark"/>

        <TextView
            android:id="@+id/btnApply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/filter_apply"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:textColor="@color/colorWhite"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>