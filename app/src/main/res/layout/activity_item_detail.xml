<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorBackground"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/colorPrimary"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/common_details"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextDark"/>

        <ImageView
            android:id="@+id/ivShare"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_share"
            app:tint="@color/colorPrimary"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/ivFavorite"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/btn_star_big_off"
            app:tint="@color/colorPrimary"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Ảnh sản phẩm -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/ivItemImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:background="@color/colorInputBg"/>

                <!-- Dot indicator ảnh -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_active"
                        android:layout_marginEnd="4dp"/>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_inactive"
                        android:layout_marginEnd="4dp"/>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_inactive"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Content card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/colorBackground"
                android:padding="16dp">

                <!-- Category + Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/category_kitchen_dining"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextGray"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <!-- Status badge -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/common_available_now"
                        android:textSize="12sp"
                        android:textColor="@color/colorWhite"
                        android:textStyle="bold"
                        android:background="@drawable/bg_status_available"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <!-- Item title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/common_item_title"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"
                    android:layout_marginBottom="16dp"/>

                <!-- Owner info card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp">

                    <!-- Owner avatar -->
                    <ImageView
                        android:id="@+id/ivOwnerAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:padding="10dp"
                        app:tint="@color/colorPrimary"/>

                    <!-- Owner name + rating -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvOwnerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/common_owner_name"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextDark"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/btn_star_big_on"
                                app:tint="#FFC107"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/detail_rating_placeholder"
                                android:textSize="12sp"
                                android:textColor="@color/colorTextGray"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- View Profile -->
                    <TextView
                        android:id="@+id/tvViewProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detail_view_profile"
                        android:textSize="11sp"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- About this item -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_about_item"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/common_description_placeholder"
                    android:textSize="14sp"
                    android:textColor="@color/colorTextGray"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="16dp"/>

                <!-- Trust badges -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <!-- Verified Member -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="@color/colorPrimary"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_verified_member"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextDark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_identity_confirmed"
                            android:textSize="11sp"
                            android:textColor="@color/colorTextGray"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <!-- Damage Protection -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="@color/colorPrimary"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_damage_protection"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextDark"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_damage_body"
                            android:textSize="11sp"
                            android:textColor="@color/colorTextGray"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Location -->
<!--                <LinearLayout-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:orientation="horizontal"-->
<!--                    android:gravity="center_vertical"-->
<!--                    android:layout_marginBottom="16dp">-->

<!--                    <ImageView-->
<!--                        android:layout_width="16dp"-->
<!--                        android:layout_height="16dp"-->
<!--                        android:src="@android:drawable/ic_menu_mapmode"-->
<!--                        app:tint="@color/colorPrimary"/>-->

<!--                    <TextView-->
<!--                        android:id="@+id/tvLocation"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text=" Community • 0.8 miles away"-->
<!--                        android:textSize="13sp"-->
<!--                        android:textColor="@color/colorTextGray"/>-->
<!--                </LinearLayout>-->

                <!-- Location clickable → mở map -->
                <LinearLayout
                    android:id="@+id/llLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Map preview thumbnail -->
                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_featured_card"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_mapmode"
                            android:tint="@color/colorPrimary"
                            android:padding="12dp"
                            android:scaleType="centerInside"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/detail_pickup_location"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextDark"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/common_loading_location"
                            android:textSize="12sp"
                            android:textColor="@color/colorTextGray"
                            android:maxLines="2"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/map_tap_to_view"
                            android:textSize="11sp"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorWhite"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="8dp">

        <!-- Chat button -->
        <Button
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="@string/common_chat"
            android:textColor="@color/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <!-- Request Item button -->
        <Button
            android:id="@+id/btnRequestItem"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:background="@drawable/bg_button_primary"
            android:text="@string/detail_request_item"
            android:textColor="@color/colorWhite"
            android:textSize="15sp"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>
