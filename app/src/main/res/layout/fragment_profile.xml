<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/ivAppAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_circle"
            android:src="@android:drawable/ic_menu_myplaces"
            android:padding="8dp"
            android:tint="@color/colorPrimary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="The Commons"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextDark"
            android:layout_marginStart="10dp"/>

        <!-- Settings icon -->
        <ImageView
            android:id="@+id/ivSettings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="@color/colorPrimary"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Bell icon -->
        <ImageView
            android:id="@+id/ivNotification"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="@color/colorPrimary"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Avatar + Name + Location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="20dp">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_avatar_circle"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:padding="20dp"
                        android:tint="@color/colorPrimary"
                        android:scaleType="centerCrop"/>

                    <!-- Verified badge -->
                    <ImageView
                        android:id="@+id/ivVerified"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:src="@android:drawable/checkbox_on_background"
                        android:tint="@color/colorPrimary"
                        android:background="@drawable/bg_card_white"
                        android:padding="2dp"/>
                </FrameLayout>

                <!-- Full Name -->
                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"
                    android:layout_marginTop="12dp"/>

                <!-- Location -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_mapmode"
                        android:tint="@color/colorTextGray"/>

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Your location"
                        android:textSize="14sp"
                        android:textColor="@color/colorTextGray"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tab: Shared / Requested -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tabShared"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Shared"
                    android:textSize="14sp"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_active"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tabRequested"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Requested"
                    android:textSize="14sp"
                    android:textColor="@color/colorTextGray"
                    android:background="@drawable/bg_tab_inactive"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Featured item (lớn) -->
            <FrameLayout
                android:id="@+id/flFeaturedItem"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_featured_card"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivFeaturedImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>

                <!-- Overlay tối phía dưới -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_image_overlay"/>

                <!-- Badge Active Share -->
                <TextView
                    android:id="@+id/tvFeaturedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE SHARE"
                    android:textSize="10sp"
                    android:textColor="@color/colorWhite"
                    android:textStyle="bold"
                    android:background="@drawable/bg_featured_badge"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="12dp"/>

                <!-- Title + subtitle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom"
                    android:padding="12dp"
                    android:paddingStart="12dp">

                    <TextView
                        android:id="@+id/tvFeaturedTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Item Title"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorWhite"
                        android:layout_marginTop="24dp"/>

                    <TextView
                        android:id="@+id/tvFeaturedSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Shared with • 2 days ago"
                        android:textSize="12sp"
                        android:textColor="#CCFFFFFF"/>
                </LinearLayout>

                <!-- Arrow icon -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@color/colorWhite"/>
            </FrameLayout>

            <!-- Grid 2 cột items -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProfileItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

            <!-- My Posts button -->
            <LinearLayout
                android:id="@+id/btnMyPosts"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="@color/colorPrimary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Posts"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@color/colorTextHint"/>
            </LinearLayout>

            <!-- History button -->
            <LinearLayout
                android:id="@+id/btnHistory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:tint="@color/colorPrimary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="History"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@color/colorTextHint"/>
            </LinearLayout>

            <!-- Settings button -->
            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    android:tint="@color/colorPrimary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextDark"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@color/colorTextHint"/>
            </LinearLayout>

            <!-- Logout button -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    android:tint="@color/colorRed"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logout"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorRed"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@color/colorRed"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>